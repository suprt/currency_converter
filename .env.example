# .env.example - скопируй в .env и заполни

# API ключ (обязательно!)
API_KEY=c8ca09278cb7e5420df3f0e9df5d0e92fea6

# Сервер
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USE=true

# Rate limiter (10 запросов/сек, burst 20)
RATE_LIMIT=10
RATE_BURST=20
RATE_CLEANUP_MIN=5m


# Как часто обновлять курсы (1 час)
UPDATE_INTERVAL=1h

# Админка
ADMIN_API_KEY=admin-secret-key-123

# Внешнее API
API_BASE_URL=https://currencyapi.net/api/v2